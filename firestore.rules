rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Blog posts: anyone can read, only admins can write
    match /blogs/{blogId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'admin@tigerfitpro.in';
    }

    // Newsletter subscribers: anyone can create, only admins can read/delete
    match /subscribers/{email} {
      allow create: if true;
      allow read, delete: if request.auth != null && request.auth.token.email == 'admin@tigerfitpro.in';
    }
  }
}
